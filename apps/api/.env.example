# Server
PORT=8080
NODE_ENV=development

# Allow the dev-mock Telegram initData (no valid HMAC). NEVER set this in production.
ALLOW_DEV_AUTH=true

# CORS — comma-separated list of frontend origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app

# Telegram bot — from @BotFather
BOT_TOKEN=PUT-YOUR-BOT-TOKEN-HERE
BOT_USERNAME=YourBotUsername
# Public URL where this API is reachable (used for the Telegram webhook).
# On Render this is the service URL, e.g. https://novamine-api.onrender.com
PUBLIC_API_URL=http://localhost:8080
# Webhook secret to confirm incoming updates really come from Telegram
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Supabase — from Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# Project Settings → API → JWT Secret. Used to mint Supabase-compatible JWTs for users.
SUPABASE_JWT_SECRET=YOUR-SUPABASE-JWT-SECRET

# TON wallet (admin destination — withdrawals are processed manually for v1)
TON_WALLET_ADDRESS=YOUR-TON-WALLET-ADDRESS

# JWT lifetime in seconds (default: 7 days)
JWT_EXPIRES_IN=604800
